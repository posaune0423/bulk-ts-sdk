# Main wallet mode: this is the only wallet variable required when signing directly with the main wallet.
MAIN_WALLET_PRIVATE_KEY=

# Agent wallet mode: set both values when an agent wallet signs for the main wallet.
AGENT_WALLET_PRIVATE_KEY=
MAIN_WALLET_PUBLIC_KEY=

# Optional endpoint overrides.
BULK_HTTP_URL=https://exchange-api.bulk.trade/api/v1
BULK_WS_URL=wss://exchange-ws1.bulk.trade

# Optional multisig E2E target.
MULTISIG_PUBKEY=
